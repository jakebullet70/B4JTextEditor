AppType=JavaFX
Build1=Default,b4j.example
File1=EditorShortcuts.md
FileGroup1=Default Group
Group=Default Group
Library1=jcore
Library2=jfx
Library3=jxui
Library4=javaobject
Module1=CodeEditor
Module2=Document
Module3=FindBar
Module4=formHelpers
Module5=SetupBar
