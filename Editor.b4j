#Region Find
Sub mnuFind_Action
	Bar.ShowFind
End Sub

Sub mnuFindNext_Action
	Bar.FindNextOrShow
End Sub

Sub mnuReplace_Action
	Bar.ShowReplace
End Sub

Sub mnuGoto_Action
	Dim s As String = InputDialog("Go to Line", "Line number:", "")
	If s = "" Or IsNumber(s) = False Then Return
	Dim line As Int = s
	Dim maxLines As Int = CountLines(Editor.Text)
	If line < 1 Then line = 1
	If line > maxLines Then line = maxLines
	Editor.GotoLine(line - 1)
	Editor.RequestFocus
End Sub

Sub CountLines (t As String) As Int
	Dim n As Int = 1
	Dim i As Int = t.IndexOf(Chr(10))
	Do While i <> -1
		n = n + 1
		i = t.IndexOf2(Chr(10), i + 1)
	Loop
	Return n
End Sub

' Modal text-input dialog via JavaFX TextInputDialog (no extra library needed).
Sub InputDialog (title As String, header As String, initial As String) As String
	Dim d As JavaObject
	d.InitializeNewInstance("javafx.scene.control.TextInputDialog", Array(initial))
	d.RunMethod("setTitle", Array(title))
	d.RunMethod("setHeaderText", Array(header))
	Dim opt As JavaObject = d.RunMethod("showAndWait", Null)
	If opt.RunMethod("isPresent", Null) Then Return opt.RunMethod("get", Null)
	Return ""
End Sub
#End Region

#Region View / status
Sub mnuWrap_Action
	SetWordWrap(mnuWrap.Selected)   ' persist + apply to all editors (also keeps the Setup panel in step)
End Sub

Sub mnuThisDoc_Action
	DocBar.Show(Encoding, Eol, DocReadOnly)   ' active document's encoding / line endings / read-only
End Sub

' Manual language pick from View > Language. Sender is the chosen MenuItem.
Sub mnuLang_Action
	Dim mi As MenuItem = Sender
	Highlighter.SetLanguageByName(mi.Tag)
	Highlighter.Highlight(Editor.Text)
	LastHLText = Editor.Text
	UpdateStatus
End Sub

Sub mnuAbout_Action
	xui.MsgboxAsync("Editor " & "1.0" & CRLF & CRLF & "A B4J desktop text editor.", "About " & APP_NAME)
End Sub

' Opens the bundled editor-shortcuts markdown in a new read-only tab.
Sub mnuShortcuts_Action
	Dim content As String
	Try
		content = File.ReadString(File.DirAssets, "EditorShortcuts.md")
	Catch
		Log(LastException)
		content = "Editor shortcuts file not found."
	End Try
	OpenHelpDoc("Editor Shortcuts", content)
End Sub

' Opens read-only text in a new tab with a custom title (used for the help/shortcuts doc).
Sub OpenHelpDoc (title As String, content As String)
	NewDoc
	Editor.Text = content
	Editor.ScrollToTop
	DisplayName = title
	Highlighter.SetLanguageByName("Markdown")
	Highlighter.Highlight(content)
	LastHLText = content
	SetReadOnly(True)
	SetBaseline                ' clean - no save prompt; refreshes the tab text via DisplayName
End Sub

Sub mnuSetup_Action
	' Global settings only; per-document encoding/EOL live in the This Document panel.
	Setup.Show(CreateMap( _
		"theme": SettingTheme, "fontfamily": SettingFontFamily, "fontsize": SettingFontSize, _
		"tabsize": SettingTabSize, "softtabs": SettingSoftTabs, "linenumbers": SettingLineNumbers, _
		"wordwrap": SettingWordWrap, "highlightline": SettingHighlightLine, "autoindent": SettingAutoIndent, _
		"defenc": SettingEncoding, "defeol": SettingEol))
End Sub

' --- Editor settings (tab size, line numbers) ---
' Called by SetupBar when the user edits a value: update, apply to all editors, persist.
Public Sub SetTabSize (n As Int)
	SettingTabSize = n
	ApplySettingsAll
	SaveSettings
End Sub

Public Sub SetLineNumbers (b As Boolean)
	SettingLineNumbers = b
	ApplySettingsAll
	SaveSettings
End Sub

' --- Per-document (active tab) ---
' Sets the active document's line ending (used on its next save).
Public Sub SetEol (e As String)
	Eol = e
	If mActiveIndex >= 0 And mActiveIndex < Documents.Size Then
		Dim d As Document = Documents.Get(mActiveIndex)
		d.eol = e
	End If
	UpdateStatus
End Sub

' Sets the active document's encoding (used on its next save).
Public Sub SetEncoding (e As String)
	Encoding = e
	If mActiveIndex >= 0 And mActiveIndex < Documents.Size Then
		Dim d As Document = Documents.Get(mActiveIndex)
		d.encoding = e
	End If
	UpdateStatus
End Sub

' Toggles read-only on the active document (blocks edits; shown in the status bar).
Public Sub SetReadOnly (b As Boolean)
	DocReadOnly = b
	If mActiveIndex >= 0 And mActiveIndex < Documents.Size Then
		Dim d As Document = Documents.Get(mActiveIndex)
		d.readonly = b
	End If
	Editor.SetEditable(Not(b))
	UpdateStatus
End Sub

' --- Defaults for new documents (persisted) ---
Public Sub SetDefaultEol (e As String)
	SettingEol = e
	SaveSettings
End Sub

Public Sub SetDefaultEncoding (e As String)
	SettingEncoding = e
	SaveSettings
End Sub

Public Sub SetFontFamily (f As String)
	SettingFontFamily = f
	ApplySettingsAll
	SaveSettings
End Sub

Public Sub SetFontSize (n As Int)
	SettingFontSize = n
	ApplySettingsAll
	SaveSettings
End Sub

Public Sub SetSoftTabs (b As Boolean)
	SettingSoftTabs = b
	ApplySettingsAll
	SaveSettings
End Sub

Public Sub SetWordWrap (b As Boolean)
	SettingWordWrap = b
	mnuWrap.Selected = b                ' keep the View menu check in sync (panel may have changed it)
	ApplySettingsAll
	SaveSettings
End Sub

Public Sub SetHighlightLine (b As Boolean)
	SettingHighlightLine = b
	ApplySettingsAll
	SaveSettings
End Sub

Public Sub SetAutoIndent (b As Boolean)
	SettingAutoIndent = b
	ApplySettingsAll
	SaveSettings
End Sub

Sub ApplySettings (ed As CodeEditor)
	ed.SetTabSize(SettingTabSize)
	ed.SetLineNumbers(SettingLineNumbers)
	ed.SetFont(SettingFontFamily, SettingFontSize)
	ed.SetSoftTabs(SettingSoftTabs)
	ed.SetWrap(SettingWordWrap)
	ed.SetAutoIndent(SettingAutoIndent)
	ed.SetHighlightLine(SettingHighlightLine)
End Sub

Sub ApplySettingsAll
	For Each d As Document In Documents
		ApplySettings(d.editor)
	Next
End Sub

Sub LoadSettings
	Dim dir As String = File.DirData(APP_NAME)
	If File.Exists(dir, CFG_FILE) Then
		Try
			Dim m As Map = File.ReadMap(dir, CFG_FILE)
			If m.ContainsKey("tabsize") Then SettingTabSize = m.Get("tabsize")
			If m.ContainsKey("linenumbers") Then SettingLineNumbers = (m.Get("linenumbers") = "true")
			If m.ContainsKey("eol") Then SettingEol = m.Get("eol")
			If m.ContainsKey("fontfamily") Then SettingFontFamily = m.Get("fontfamily")
			If m.ContainsKey("fontsize") Then SettingFontSize = m.Get("fontsize")
			If m.ContainsKey("softtabs") Then SettingSoftTabs = (m.Get("softtabs") = "true")
			If m.ContainsKey("wordwrap") Then SettingWordWrap = (m.Get("wordwrap") = "true")
			If m.ContainsKey("theme") Then SettingTheme = m.Get("theme")
			If m.ContainsKey("encoding") Then SettingEncoding = m.Get("encoding")
			If m.ContainsKey("highlightline") Then SettingHighlightLine = (m.Get("highlightline") = "true")
			If m.ContainsKey("autoindent") Then SettingAutoIndent = (m.Get("autoindent") = "true")
		Catch
			Log(LastException)
		End Try
	End If
	If SettingTabSize < 1 Or SettingTabSize > 16 Then SettingTabSize = 3   ' guard bad/old values
	If SettingEol <> "LF" Then SettingEol = "CRLF"                          ' guard bad/old values
	If SettingFontSize < 6 Or SettingFontSize > 72 Then SettingFontSize = 14
	If SettingFontFamily = "" Then SettingFontFamily = "Consolas"
	If SettingTheme <> "Dark" Then SettingTheme = "Light"
	If EncodingNames.IndexOf(SettingEncoding) < 0 Then SettingEncoding = "UTF-8"
End Sub

Sub SaveSettings
	Dim m As Map = CreateMap( _
		"tabsize": SettingTabSize, "linenumbers": SettingLineNumbers, "eol": SettingEol, _
		"fontfamily": SettingFontFamily, "fontsize": SettingFontSize, _
		"softtabs": SettingSoftTabs, "wordwrap": SettingWordWrap, _
		"theme": SettingTheme, "encoding": SettingEncoding, _
		"highlightline": SettingHighlightLine, "autoindent": SettingAutoIndent)
	Try
		File.WriteMap(File.DirData(APP_NAME), CFG_FILE, m)
	Catch
		Log(LastException)
	End Try
End Sub

' Polls caret/length each tick; on any activity it refreshes Ln/Col and recomputes the modified
' flag by comparing the text to the last saved/loaded Baseline. Idle ticks return early.
Sub caretTimer_Tick
	Dim c As Int = Editor.GetCaret
	Dim len As Int = Editor.TextLength
	If c = LastCaret And len = LastLen Then Return
	LastCaret = c
	LastLen = len
	Dim curText As String = Editor.Text
	Dim nowMod As Boolean = (curText <> Baseline)
	If nowMod <> Modified Then SetModified(nowMod)
	If curText <> LastHLText Then       ' content changed - re-highlight (debounced by the 150ms tick)
		LastHLText = curText
		Highlighter.Highlight(curText)
	End If
	Editor.RefreshCurrentLine           ' move the current-line highlight to the caret's line
	UpdateStatus
End Sub

Sub UpdateStatus
	Dim ln As Int = Editor.GetCaretLine
	Dim col As Int = Editor.GetCaretColumn
	Dim modFlag As String = ""
	If Modified Then modFlag = "   modified"
	Dim roFlag As String = ""
	If DocReadOnly Then roFlag = "   read-only"
	lblStatus.Text = $"Ln ${ln}, Col ${col}      ${Encoding}      ${Eol}      ${Highlighter.CurrentName}${roFlag}${modFlag}"$
End Sub

' Marks the current text as the clean baseline (called after New / Open / Save).
Sub SetBaseline
	Baseline = Editor.Text
	LastLen = Editor.TextLength
	LastCaret = Editor.GetCaret
	SetModified(False)
End Sub

Sub SetModified (b As Boolean)
	Modified = b
	UpdateTitle
	UpdateActiveTabText
End Sub

Sub UpdateTitle
	Dim star As String = ""
	If Modified Then star = "*"
	MainForm.Title = star & DocName & " - " & APP_NAME
End Sub
#End Region

#Region Helpers
Sub DocName As String
	If DisplayName <> "" Then Return DisplayName   ' help/shortcuts doc, etc.
	If CurrentPath = "" Then Return "Untitled"
	Return GetName(CurrentPath)
End Sub

Sub GetName (path As String) As String
	Dim jf As JavaObject
	jf.InitializeNewInstance("java.io.File", Array(path))
	Return jf.RunMethod("getName", Null)
End Sub

Sub GetParentDir (path As String) As String
	Dim jf As JavaObject
	jf.InitializeNewInstance("java.io.File", Array(path))
	Dim p As Object = jf.RunMethod("getParent", Null)
	If p = Null Then Return ""
	Return p
End Sub

Sub GetExt (name As String) As String
	Dim i As Int = name.LastIndexOf(".")
	If i = -1 Then Return ""
	Return name.SubString(i + 1)
End Sub

#Region Encoding
' Encoding names used in the UI: "UTF-8", "UTF-8 BOM", "UTF-16 LE", "UTF-16 BE", "ANSI".
' Detects a byte-order mark; falls back to the configured default when none is present.
Sub DetectEncoding (data() As Byte, fallback As String) As String
	If data.Length >= 3 And U(data(0)) = 0xEF And U(data(1)) = 0xBB And U(data(2)) = 0xBF Then Return "UTF-8 BOM"
	If data.Length >= 2 And U(data(0)) = 0xFF And U(data(1)) = 0xFE Then Return "UTF-16 LE"
	If data.Length >= 2 And U(data(0)) = 0xFE And U(data(1)) = 0xFF Then Return "UTF-16 BE"
	Return fallback
End Sub

Sub U (b As Byte) As Int
	Return Bit.And(b, 0xFF)        ' unsigned value of a (signed) B4X byte
End Sub

' Number of BOM bytes at the start (to skip when decoding).
Sub BomLength (data() As Byte) As Int
	If data.Length >= 3 And U(data(0)) = 0xEF And U(data(1)) = 0xBB And U(data(2)) = 0xBF Then Return 3
	If data.Length >= 2 And U(data(0)) = 0xFF And U(data(1)) = 0xFE Then Return 2
	If data.Length >= 2 And U(data(0)) = 0xFE And U(data(1)) = 0xFF Then Return 2
	Return 0
End Sub

Sub DecodeBytes (data() As Byte, enc As String) As String
	Dim off As Int = BomLength(data)
	Return BytesToString(data, off, data.Length - off, CharsetFor(enc))
End Sub

' Encodes text to bytes for the given encoding, prepending a BOM where the encoding calls for one.
Sub EncodeText (text As String, enc As String) As Byte()
	Dim body() As Byte = text.GetBytes(CharsetFor(enc))
	Dim bom() As Byte = BomBytes(enc)
	If bom.Length = 0 Then Return body
	Dim out(bom.Length + body.Length) As Byte
	Dim i As Int
	For i = 0 To bom.Length - 1
		out(i) = bom(i)
	Next
	For i = 0 To body.Length - 1
		out(bom.Length + i) = body(i)
	Next
	Return out
End Sub

' Maps a UI encoding name to a Java charset.
Sub CharsetFor (enc As String) As String
	Select enc
		Case "UTF-8", "UTF-8 BOM"
			Return "UTF-8"
		Case "UTF-16 LE"
			Return "UTF-16LE"
		Case "UTF-16 BE"
			Return "UTF-16BE"
	End Select
	Return "UTF-8"
End Sub

' BOM bytes for an encoding (empty when none) - derived by encoding the U+FEFF BOM char.
Sub BomBytes (enc As String) As Byte()
	Dim mark As String = Chr(0xFEFF)        ' U+FEFF; Chr returns a Char, so hold it as a String
	Select enc
		Case "UTF-8 BOM"
			Return mark.GetBytes("UTF-8")
		Case "UTF-16 LE"
			Return mark.GetBytes("UTF-16LE")
		Case "UTF-16 BE"
			Return mark.GetBytes("UTF-16BE")
	End Select
	Dim empty(0) As Byte
	Return empty
End Sub

' The encoding names offered in the Setup combos. All non-default encodings carry a BOM, so they
' are detected automatically on open (no per-file memory needed).
Sub EncodingNames As List
	Return Array As String("UTF-8", "UTF-8 BOM", "UTF-16 LE", "UTF-16 BE")
End Sub
#End Region

' Writes the theme (editor colors + syntax-highlight palette) to a real temp file and points CssUri
' at it. (DirAssets is virtual in Release, so a CSS stylesheet needs a real file URI.) Each call uses
' a fresh filename so re-attaching the stylesheet actually reloads (JavaFX caches by URL).
Sub InstallTheme
	mThemeCounter = mThemeCounter + 1
	Dim css As String = BuildThemeCss(SettingTheme)
	Dim fname As String = "syntax" & mThemeCounter & ".css"
	File.WriteString(File.DirTemp, fname, css)
	Dim path As String = File.Combine(File.DirTemp, fname)
	CssUri = "file:///" & path.Replace("\", "/")
End Sub

' Switches theme: rewrite the stylesheet and re-point every open editor at it.
Public Sub SetTheme (t As String)
	SettingTheme = t
	InstallTheme
	For Each d As Document In Documents
		d.editor.SetStylesheet(CssUri)
	Next
	fhelper.SetSceneStylesheet(CssUri)   ' editor/token rules
	ApplyChromeBase                       ' menu/tabs/controls/popups
	SaveSettings
End Sub

' Sets modena's base colors as an INLINE style on the scene root, so all chrome (menu bar, tabs,
' buttons, fields, combos) re-derives. Doing this on the node - rather than a `.root` CSS rule on the
' scene - keeps combo/menu popups (which live in their own scene) resolving looked-up colors cleanly
' through the node parent chain; a competing `.root` rule there triggers modena CssStyleHelper warnings.
Sub ApplyChromeBase
	If SettingTheme = "Dark" Then
		MainForm.RootPane.Style = "-fx-base: #3c3f41; -fx-background: #2d2f31; -fx-control-inner-background: #313335; -fx-accent: #4b6eaf;"
	Else
		MainForm.RootPane.Style = "-fx-base: #ececec; -fx-background: #f4f4f4; -fx-control-inner-background: #ffffff; -fx-accent: #0096c9;"
	End If
End Sub

' Returns the full CSS for a theme: editor background, default text, gutter, caret, selection, and
' the token palette (keyword/string/char/number/comment/annotation).
Sub BuildThemeCss (theme As String) As String
	Dim bg, fg, kw, str, num, cmt, ann, typ, gbg, gfg, caret, sel, curline As String
	If theme = "Dark" Then
		bg = "#1e1e1e" : fg = "#d4d4d4"
		kw = "#569cd6" : str = "#ce9178" : num = "#b5cea8" : cmt = "#6a9955" : ann = "#dcdcaa" : typ = "#4ec9b0"
		gbg = "#2b2b2b" : gfg = "#858585" : caret = "#d4d4d4" : sel = "#264f78" : curline = "#2a2d2e"
	Else
		bg = "#ffffff" : fg = "#1e1e1e"
		kw = "#0000ff" : str = "#a31515" : num = "#098658" : cmt = "#008000" : ann = "#808000" : typ = "#267f99"
		gbg = "#f0f0f0" : gfg = "#999999" : caret = "#1e1e1e" : sel = "#b5d5ff" : curline = "#eef3fb"
	End If
	Return $".code-area{-fx-background-color:${bg};}"$ _
		& $".code-area .text{-fx-fill:${fg};}"$ _
		& $".current-line{-fx-background-color:${curline};}"$ _
		& $".lineno{-fx-background-color:${gbg};-fx-text-fill:${gfg};}"$ _
		& $".caret{-fx-stroke:${caret};}"$ _
		& $".selection{-fx-fill:${sel};}"$ _
		& $".code-area .text.keyword{-fx-fill:${kw};-fx-font-weight:bold;}"$ _
		& $".code-area .text.type{-fx-fill:${typ};}"$ _
		& $".code-area .text.string{-fx-fill:${str};}.code-area .text.char{-fx-fill:${str};}"$ _
		& $".code-area .text.number{-fx-fill:${num};}"$ _
		& $".code-area .text.comment{-fx-fill:${cmt};-fx-font-style:italic;}"$ _
		& $".code-area .text.annotation{-fx-fill:${ann};}"$
End Sub
#End Region
