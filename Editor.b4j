@EndOfDesignText@
#Region Project Attributes
	#MainFormWidth: 900
	#MainFormHeight: 600
	
	#AdditionalJar: richtextfx-0.11.7
	#AdditionalJar: flowless-0.7.4
	#AdditionalJar: undofx-2.1.1
	#AdditionalJar: wellbehavedfx-0.3.3
	#AdditionalJar: reactfx-2.0-M5
#End Region

Sub Process_Globals
	Private fx As JFX
	Private MainForm As Form
	Private xui As XUI
	Private fhelper As formHelpers
	Private Editor As CodeEditor            ' points at the ACTIVE document's editor (re-assigned on tab switch)
	Private tabs As TabPane                 ' one tab per open document
	Private Documents As List               ' List of Document, index-aligned with tabs.Tabs
	Private mActiveIndex As Int = -1        ' index of the document currently mirrored into the globals below
	Private mDocCounter As Int = 0          ' generates unique tab ids
	Private CssUri As String                ' file URI of the shared syntax-highlight stylesheet
	Private mb As MenuBar
	Private mnuWrap As CheckMenuItem
	Private lblStatus As Label
	Private caretTimer As Timer
	Private LastCaret As Int = -1
	Private LastLen As Int = -1
	Private Baseline As String = ""         ' last saved/loaded text - drives the modified flag
	' These globals MIRROR the active Document (see SaveActiveTo / LoadActiveFrom).
	Private CurrentPath As String = ""
	Private CurrentDir As String = ""
	Private Modified As Boolean = False
	Private Eol As String = "CRLF"          ' "LF" or "CRLF"
	Private Encoding As String = "UTF-8"
	Private DocReadOnly As Boolean = False  ' active doc is read-only (file attr or user toggle)
	Private DisplayName As String = ""      ' custom tab/title name (help doc); "" = use file name
	Private Highlighter As SyntaxHL
	Private Bar As FindBar
	Private Setup As SetupBar
	Private DocBar As ThisDocBar            ' "This Document" panel (active doc's encoding/EOL)
	Private LastHLText As String = Chr(0)    ' last highlighted text (forces an initial highlight)
	' Editor settings (persisted to CFG_FILE; applied to every open editor).
	Private SettingTabSize As Int = 3
	Private SettingLineNumbers As Boolean = True
	Private SettingEol As String = "CRLF"   ' default line ending for new documents
	Private SettingFontFamily As String = "Consolas"
	Private SettingFontSize As Int = 14
	Private SettingSoftTabs As Boolean = True   ' True = Tab inserts spaces; False = real tab char
	Private SettingWordWrap As Boolean = False
	Private SettingTheme As String = "Light"    ' "Light" or "Dark"
	Private SettingEncoding As String = "UTF-8" ' default encoding for new docs / no-BOM opened files
	Private SettingHighlightLine As Boolean = True
	Private SettingAutoIndent As Boolean = True
	Private mThemeCounter As Int = 0            ' unique stylesheet filename per theme apply (cache-bust)
	Private RecentFiles As List                 ' MRU file paths (most recent first), persisted
	Private mRecent As Menu                     ' File > Open Recent submenu (rebuilt on change)
	Private Const RECENT_FILE As String = "recent.txt"
	Private Const RECENT_MAX As Int = 10
	Private Const APP_NAME As String = "B4J Editor"
	Private Const POS_FILE As String = "window.properties"
	Private Const CFG_FILE As String = "settings.properties"
	Private Const MENU_H As Double = 28
	Private Const STATUS_H As Double = 24
End Sub

Sub AppStart (Form1 As Form, Args() As String)
	MainForm = Form1
	fhelper.Initialize(MainForm)
	LoadSettings                                ' restore tab size / line-numbers before the first doc
	LoadRecent                                  ' restore the recent-files list before the menu is built
	BuildUI                                     ' builds directly on MainForm.RootPane (an AnchorPane)
	NewDoc                                       ' start with one empty Untitled tab

	caretTimer.Initialize("caretTimer", 150)
	caretTimer.Enabled = True
	MainForm.Show
	fhelper.LoadFormPosition(File.DirData(APP_NAME), POS_FILE)   ' restore last window position/size
	fhelper.InstallFileDrop                      ' enable drag-drop to open (scene exists after Show)
	fhelper.SetSceneStylesheet(CssUri)           ' apply the theme to the whole window chrome
	UpdateStatus
	Editor.RequestFocus
End Sub

' Opens a file dropped onto the window (routed from formHelpers).
Public Sub OpenDroppedFile (path As String)
	If File.Exists(GetParentDir(path), GetName(path)) Then OpenDoc(path)
End Sub

' Persists the window position/size whenever the app closes (any path).
Sub MainForm_Closed
	fhelper.SaveFormPosition(File.DirData(APP_NAME), POS_FILE)
End Sub

#Region UI construction
Sub BuildUI
	InstallTheme              ' writes the theme CSS and sets CssUri (applied per-document editor)
	Highlighter.Initialize
	Documents.Initialize

	' Tabbed editor area fills between the menu bar (top) and status bar (bottom).
	tabs.Initialize("tabs")
	' Show the close (X) on every tab, not just the selected one.
	Dim tpjo As JavaObject = tabs
	Dim closePolicy As JavaObject
	closePolicy.InitializeStatic("javafx.scene.control.TabPane$TabClosingPolicy")
	tpjo.RunMethod("setTabClosingPolicy", Array(closePolicy.GetField("ALL_TABS")))
	MainForm.RootPane.AddNode(tabs, 0, MENU_H, 900, 548)
	SetAnchors(tabs, MENU_H, 0.0, STATUS_H, 0.0)

	' Status bar pinned to the bottom, full width.
	lblStatus.Initialize("")
	lblStatus.Style = "-fx-background-color: -fx-background; -fx-text-fill: -fx-text-base-color; -fx-padding: 4 10 4 10; -fx-font-family: 'Segoe UI'; -fx-font-size: 12;"
	MainForm.RootPane.AddNode(lblStatus, 0, 576, 900, STATUS_H)
	lblStatus.PrefHeight = STATUS_H
	SetAnchors(lblStatus, Null, 0.0, 0.0, 0.0)

	' Menu bar pinned to the top, full width.
	BuildMenuBar
	MainForm.RootPane.AddNode(mb, 0, 0, 900, MENU_H)
	mb.PrefHeight = MENU_H
	SetAnchors(mb, 0.0, 0.0, Null, 0.0)

	' Floating find/replace bar, pinned top-right over the editor (hidden until Ctrl+F / Ctrl+R).
	Bar.Initialize(Highlighter)
	Dim bp As Pane = Bar.AsPanel
	MainForm.RootPane.AddNode(bp, 420, MENU_H + 8, bp.PrefWidth, bp.PrefHeight)
	SetAnchors(bp, MENU_H + 8, 18.0, Null, Null)

	' Floating Setup panel, pinned top-right (hidden until Help > Setup). Use the panel's own pref
	' size so its height stays the single source of truth (SetupBar.H).
	Setup.Initialize
	Dim sp As Pane = Setup.AsPanel
	MainForm.RootPane.AddNode(sp, 630, MENU_H + 8, sp.PrefWidth, sp.PrefHeight)
	SetAnchors(sp, MENU_H + 8, 18.0, Null, Null)

	' Floating "This Document" panel, pinned top-right (hidden until View > This Document).
	DocBar.Initialize
	Dim dp As Pane = DocBar.AsPanel
	MainForm.RootPane.AddNode(dp, 580, MENU_H + 8, dp.PrefWidth, dp.PrefHeight)
	SetAnchors(dp, MENU_H + 8, 18.0, Null, Null)

	ApplyChromeBase           ' theme the menu/tabs/controls via inline base colors on the root
End Sub

#Region Documents / tabs
' Creates a new empty document in a new tab and switches to it.
Sub NewDoc
	Dim d As Document
	d.Initialize(CssUri)
	d.eol = SettingEol                                   ' new docs start with the default line ending
	d.encoding = SettingEncoding                         ' ...and the default encoding
	ApplySettings(d.editor)                              ' tab size + line-numbers for this editor
	Dim tp As TabPage : tp.Initialize
	Dim tj As JavaObject = tp
	tj.RunMethod("setContent", Array(d.editor.AsNode))   ' tab content fills automatically
	tj.RunMethod("setClosable", Array(True))             ' show the X (intercepted for a save prompt)
	mDocCounter = mDocCounter + 1
	Dim docId As String = "doc" & mDocCounter
	tp.Id = docId
	d.id = docId
	tp.Text = "Untitled"
	tp.Tag = d
	d.page = tp
	d.AttachClose                                        ' route the X through TabCloseRequest
	Documents.Add(d)
	tabs.Tabs.Add(tp)
	tabs.SelectedIndex = Documents.Size - 1
	SwitchTo(Documents.Size - 1)
End Sub

' Opens a file. Reuses the active tab if it's a pristine Untitled (empty, unmodified, no path);
' otherwise opens a new tab.
Sub OpenDoc (path As String)
	If CurrentPath = "" And Modified = False And Editor.TextLength = 0 Then
		LoadFile(path)        ' reuse the current empty Untitled tab
	Else
		NewDoc
		LoadFile(path)
	End If
End Sub

' Persists the global mirror into Document idx, then makes idx the active document.
Sub SwitchTo (idx As Int)
	If idx < 0 Or idx >= Documents.Size Then Return
	If mActiveIndex >= 0 And mActiveIndex < Documents.Size And mActiveIndex <> idx Then
		SaveActiveTo(Documents.Get(mActiveIndex))
	End If
	mActiveIndex = idx
	LoadActiveFrom(Documents.Get(idx))
End Sub

' Raised when the user clicks a different tab.
Sub tabs_TabChanged (SelectedTab As TabPage)
	Dim idx As Int = tabs.SelectedIndex
	If idx = mActiveIndex Then Return
	SwitchTo(idx)
End Sub

Sub SaveActiveTo(d As Document)
	d.path = CurrentPath
	d.dir = CurrentDir
	d.modified = Modified
	d.eol = Eol
	d.encoding = Encoding
	d.readonly = DocReadOnly
	d.displayName = DisplayName
	d.baseline = Baseline
	d.lastHLText = LastHLText
	d.langName = Highlighter.CurrentName
End Sub

Sub LoadActiveFrom(d As Document)
	Editor = d.editor                ' all later Editor.* calls target this document
	CurrentPath = d.path
	CurrentDir = d.dir
	Modified = d.modified
	Eol = d.eol
	Encoding = d.encoding
	DocReadOnly = d.readonly
	DisplayName = d.displayName
	Baseline = d.baseline
	LastHLText = d.lastHLText
	LastCaret = -1                   ' force the next caretTimer tick to refresh the status bar
	LastLen = -1
	Editor.SetEditable(Not(DocReadOnly))
	Highlighter.SetEditor(Editor)
	Highlighter.SetLanguageByName(d.langName)
	Bar.SetEditor(Editor)
	If DocBar.IsVisible Then DocBar.RefreshPerDoc(Encoding, Eol, DocReadOnly)   ' keep an open panel on the active doc
	UpdateTitle
	UpdateStatus
	Editor.RequestFocus
End Sub

Sub mnuClose_Action
	If Documents.Size = 0 Then Return
	Wait For (ConfirmDiscard) Complete (proceed As Boolean)
	If proceed Then CloseActiveDoc
End Sub

' Called (from Document's inline-Java close handler) when a tab's X is clicked.
Public Sub TabCloseRequest (tabId As String)
	Dim idx As Int = IndexOfDocId(tabId)
	If idx < 0 Then Return
	tabs.SelectedIndex = idx           ' make the clicked tab active, then prompt + close it
	SwitchTo(idx)
	Wait For (ConfirmDiscard) Complete (proceed As Boolean)
	If proceed Then CloseActiveDoc
End Sub

Sub IndexOfDocId (tabId As String) As Int
	For i = 0 To Documents.Size - 1
		Dim d As Document = Documents.Get(i)
		If d.id = tabId Then Return i
	Next
	Return -1
End Sub

Sub CloseActiveDoc
	Dim idx As Int = mActiveIndex
	If idx < 0 Then Return
	tabs.Tabs.RemoveAt(idx)
	Documents.RemoveAt(idx)
	mActiveIndex = -1                ' discard the closed doc; force a clean reload of the neighbour
	If Documents.Size = 0 Then
		NewDoc
	Else
		Dim ni As Int = idx
		If ni >= Documents.Size Then ni = Documents.Size - 1
		tabs.SelectedIndex = ni
		SwitchTo(ni)
	End If
End Sub

' Updates the active tab header to "<name>" or "*<name>" when modified.
Sub UpdateActiveTabText
	If mActiveIndex < 0 Or mActiveIndex >= Documents.Size Then Return
	Dim d As Document = Documents.Get(mActiveIndex)
	Dim star As String = ""
	If Modified Then star = "*"
	d.page.Text = star & DocName
End Sub

' True if the active document or any other open document has unsaved changes.
Sub AnyModified As Boolean
	If mActiveIndex >= 0 And mActiveIndex < Documents.Size Then SaveActiveTo(Documents.Get(mActiveIndex))
	For Each d As Document In Documents
		If d.modified Then Return True
	Next
	Return False
End Sub

' --- Cross-document access for the find bar (All tabs) ---
Public Sub DocCount As Int
	Return Documents.Size
End Sub

Public Sub DocEditorAt (i As Int) As CodeEditor
	Dim d As Document = Documents.Get(i)
	Return d.editor
End Sub

Public Sub ActiveDocIndex As Int
	Return mActiveIndex
End Sub

' Switch to document i (tab selection + global mirror); used by cross-doc Find.
Public Sub GoToDoc (i As Int)
	If i < 0 Or i >= Documents.Size Or i = mActiveIndex Then Return
	tabs.SelectedIndex = i
	SwitchTo(i)
End Sub

' Flags document i modified after a cross-doc Replace All (updates flag + tab star).
Public Sub NoteDocChanged (i As Int)
	If i < 0 Or i >= Documents.Size Then Return
	Dim d As Document = Documents.Get(i)
	d.modified = True
	If i = mActiveIndex Then
		SetModified(True)
	Else
		Dim nm As String = "Untitled"
		If d.path <> "" Then nm = GetName(d.path)
		d.page.Text = "*" & nm
	End If
End Sub
#End Region

' Applies JavaFX AnchorPane constraints so a child resizes with the form.
' Pass Null for any side that should not be anchored.
Sub SetAnchors (node As Object, top As Object, right As Object, bottom As Object, left As Object)
	Dim child As JavaObject = node
	Dim ap As JavaObject
	ap.InitializeStatic("javafx.scene.layout.AnchorPane")
	If top <> Null Then ap.RunMethod("setTopAnchor", Array(child, top))
	If right <> Null Then ap.RunMethod("setRightAnchor", Array(child, right))
	If bottom <> Null Then ap.RunMethod("setBottomAnchor", Array(child, bottom))
	If left <> Null Then ap.RunMethod("setLeftAnchor", Array(child, left))
End Sub


Sub BuildMenuBar
	mb.Initialize("mb")
	Dim mFile As Menu
	mFile.Initialize("_File", "")     ' leading underscore = Alt+F mnemonic
	AddItem(mFile, "_New", "mnuNew", "Shortcut+N")
	AddItem(mFile, "_Open...", "mnuOpen", "Shortcut+O")
	AddItem(mFile, "_Save", "mnuSave", "Shortcut+S")
	AddItem(mFile, "Save _As...", "mnuSaveAs", "Shortcut+Shift+S")
	AddItem(mFile, "_Close Tab", "mnuClose", "Shortcut+W")
	AddItem(mFile, "E_xit", "mnuExit", "Shortcut+Q")
	AddSeparator(mFile)                        ' divider, then the recent files below it
	mRecent.Initialize("Open _Recent", "")     ' submenu, populated by RebuildRecentMenu
	mFile.MenuItems.Add(mRecent)
	mb.Menus.Add(mFile)

	Dim mEdit As Menu
	mEdit.Initialize("_Edit", "")     ' Alt+E
	AddItem(mEdit, "_Undo", "mnuUndo", "Shortcut+Z")
	AddItem(mEdit, "_Redo", "mnuRedo", "Shortcut+Y")
	AddItem(mEdit, "Cu_t", "mnuCut", "Shortcut+X")
	AddItem(mEdit, "_Copy", "mnuCopy", "Shortcut+C")
	AddItem(mEdit, "_Paste", "mnuPaste", "Shortcut+V")
	AddItem(mEdit, "Select _All", "mnuSelectAll", "Shortcut+A")
	AddItem(mEdit, "_Find...", "mnuFind", "Shortcut+F")
	AddItem(mEdit, "Find _Next", "mnuFindNext", "F3")
	AddItem(mEdit, "Rep_lace...", "mnuReplace", "Shortcut+R")
	AddItem(mEdit, "_Go to Line...", "mnuGoto", "Shortcut+G")
	mb.Menus.Add(mEdit)

	Dim mView As Menu
	mView.Initialize("_View", "")     ' Alt+V
	mnuWrap.Initialize("_Word Wrap", "mnuWrap")
	mnuWrap.Selected = SettingWordWrap     ' reflect the persisted default
	SetAccelerator(mnuWrap, "Alt+Z")
	mView.MenuItems.Add(mnuWrap)
	AddItem(mView, "This _Document...", "mnuThisDoc", "")   ' active doc's encoding / line endings
	' Language submenu (auto-detected on Open; selectable manually here).
	Dim mLang As Menu
	mLang.Initialize("_Language", "")
	AddLangItem(mLang, "Plain")
	For Each nm As String In Highlighter.Names
		AddLangItem(mLang, nm)
	Next
	mView.MenuItems.Add(mLang)
	mb.Menus.Add(mView)

	Dim mHelp As Menu
	mHelp.Initialize("_Help", "")     ' Alt+H
	AddItem(mHelp, "_Setup...", "mnuSetup", "")
	AddItem(mHelp, "Editor _Shortcuts", "mnuShortcuts", "")
	AddItem(mHelp, "_About", "mnuAbout", "")
	mb.Menus.Add(mHelp)

	RebuildRecentMenu                  ' fill the Open Recent submenu from the loaded list
End Sub

Sub AddItem (m As Menu, text As String, event As String, accel As String) As MenuItem
	Dim mi As MenuItem
	mi.Initialize(text, event)
	m.MenuItems.Add(mi)
	If accel <> "" Then SetAccelerator(mi, accel)
	Return mi
End Sub

' Appends a horizontal divider to a menu (native SeparatorMenuItem; Menu.getItems() is reflection-safe
' unlike Pane.getChildren()).
Sub AddSeparator (m As Menu)
	Dim sep As JavaObject
	sep.InitializeNewInstance("javafx.scene.control.SeparatorMenuItem", Null)
	Dim mjo As JavaObject = m
	mjo.RunMethodJO("getItems", Null).RunMethod("add", Array(sep))
End Sub

Sub AddLangItem (m As Menu, langName As String)
	Dim mi As MenuItem
	mi.Initialize(langName, "mnuLang")
	mi.Tag = langName
	m.MenuItems.Add(mi)
End Sub

' Sets a keyboard accelerator on a (Check)MenuItem via JavaFX KeyCombination.
Sub SetAccelerator (item As Object, accel As String)
	Dim kcStatic As JavaObject
	kcStatic.InitializeStatic("javafx.scene.input.KeyCombination")
	Dim kc As Object = kcStatic.RunMethod("keyCombination", Array(accel))
	Dim jmi As JavaObject = item
	jmi.RunMethod("setAccelerator", Array(kc))
End Sub

#End Region

#Region File operations
Sub mnuNew_Action
	NewDoc
End Sub

Sub mnuOpen_Action
	Dim fc As FileChooser
	fc.Initialize
	fc.Title = "Open"
	If CurrentDir <> "" Then fc.InitialDirectory = CurrentDir
	Dim path As String = fc.ShowOpen(MainForm)
	If path = "" Then Return
	OpenDoc(path)
End Sub

#Region Recent files
' Opens a file chosen from File > Open Recent (path carried in the menu item's Tag).
Sub mnuRecent_Action
	Dim mi As MenuItem = Sender
	Dim path As String = mi.Tag
	If File.Exists(GetParentDir(path), GetName(path)) Then
		OpenDoc(path)
	Else
		xui.MsgboxAsync("File not found:" & CRLF & path, APP_NAME)
		RemoveRecent(path)
		SaveRecent
		RebuildRecentMenu
	End If
End Sub

Sub mnuClearRecent_Action
	RecentFiles.Initialize
	SaveRecent
	RebuildRecentMenu
End Sub

Sub mnuRecentNone_Action
	' placeholder item when the list is empty - no action
End Sub

' Moves a path to the top of the MRU list (deduped, capped), persists, and rebuilds the menu.
Sub AddRecent (path As String)
	RemoveRecent(path)
	RecentFiles.InsertAt(0, path)
	Do While RecentFiles.Size > RECENT_MAX
		RecentFiles.RemoveAt(RecentFiles.Size - 1)
	Loop
	SaveRecent
	RebuildRecentMenu
End Sub

' Removes any (case-insensitive) occurrence of path from the list.
Sub RemoveRecent (path As String)
	For i = RecentFiles.Size - 1 To 0 Step -1
		Dim p As String = RecentFiles.Get(i)
		If p.ToLowerCase = path.ToLowerCase Then RecentFiles.RemoveAt(i)
	Next
End Sub

Sub LoadRecent
	RecentFiles.Initialize
	Dim dir As String = File.DirData(APP_NAME)
	If File.Exists(dir, RECENT_FILE) Then
		Try
			RecentFiles = File.ReadList(dir, RECENT_FILE)
		Catch
			Log(LastException)
			RecentFiles.Initialize
		End Try
	End If
End Sub

Sub SaveRecent
	Try
		File.WriteList(File.DirData(APP_NAME), RECENT_FILE, RecentFiles)
	Catch
		Log(LastException)
	End Try
End Sub

' Repopulates the Open Recent submenu (one item per path + Clear; a placeholder when empty).
Sub RebuildRecentMenu
	Do While mRecent.MenuItems.Size > 0
		mRecent.MenuItems.RemoveAt(0)
	Loop
	If RecentFiles.Size = 0 Then
		Dim miNone As MenuItem
		miNone.Initialize("(no recent files)", "mnuRecentNone")
		mRecent.MenuItems.Add(miNone)
		Return
	End If
	For Each p As String In RecentFiles
		Dim mi As MenuItem
		mi.Initialize(p, "mnuRecent")
		mi.Tag = p
		mRecent.MenuItems.Add(mi)
	Next
	Dim miClear As MenuItem
	miClear.Initialize("Clear Recent List", "mnuClearRecent")
	mRecent.MenuItems.Add(miClear)
End Sub
#End Region

Sub LoadFile (path As String)
	Dim dir As String = GetParentDir(path)
	Dim name As String = GetName(path)
	Dim data() As Byte
	Try
		data = File.ReadBytes(dir, name)
	Catch
		Log(LastException)
		xui.MsgboxAsync("Could not read file:" & CRLF & path, APP_NAME)
		Return
	End Try
	Encoding = DetectEncoding(data, SettingEncoding)   ' BOM wins; else the configured default
	Dim raw As String = DecodeBytes(data, Encoding)
	If raw.Contains(Chr(13) & Chr(10)) Then
		Eol = "CRLF"
	Else
		Eol = "LF"
	End If
	Editor.Text = raw            ' programmatic set - does not flag Modified (CodeArea normalizes to LF)
	Editor.ScrollToTop           ' replaceText leaves the view at the bottom; show the top of the file
	CurrentPath = path
	CurrentDir = dir
	DisplayName = ""             ' a real file uses its file name
	DocReadOnly = (CanWrite(path) = False)   ' respect the file's read-only attribute (Win + Linux)
	Editor.SetEditable(Not(DocReadOnly))
	Highlighter.SetLanguageByExtension(GetExt(name))
	Highlighter.Highlight(raw)
	LastHLText = raw
	SetBaseline
	UpdateActiveTabText
	UpdateStatus
	AddRecent(path)
End Sub

' True if the file at path is writable (java.io.File.canWrite - honours Windows read-only attribute
' and Linux write permission).
Sub CanWrite (path As String) As Boolean
	Dim jf As JavaObject
	jf.InitializeNewInstance("java.io.File", Array(path))
	Return jf.RunMethod("canWrite", Null)
End Sub

Sub mnuSave_Action
	SaveFile(False)
End Sub

Sub mnuSaveAs_Action
	SaveFile(True)
End Sub

Sub SaveFile(forceDialog As Boolean) As ResumableSub
	Dim path As String = CurrentPath
	If forceDialog Or path = "" Then
		Dim fc As FileChooser
		fc.Initialize
		fc.Title = "Save As"
		If CurrentDir <> "" Then fc.InitialDirectory = CurrentDir
		If CurrentPath <> "" Then fc.InitialFileName = GetName(CurrentPath)
		path = fc.ShowSave(MainForm)
		If path = "" Then Return False
	End If
	Dim content As String = Editor.Text     ' uses LF internally
	If Eol = "CRLF" Then content = content.Replace(Chr(10), Chr(13) & Chr(10))
	Dim dir As String = GetParentDir(path)
	Dim name As String = GetName(path)
	Try
		File.WriteBytes(dir, name, EncodeText(content, Encoding))   ' apply encoding + BOM
	Catch
		Log(LastException)
		xui.MsgboxAsync("Could not write file:" & CRLF & path, APP_NAME)
		Return False
	End Try
	CurrentPath = path
	CurrentDir = dir
	SetBaseline
	UpdateActiveTabText
	AddRecent(path)
	Return True
End Sub

Sub mnuExit_Action
	PromptThenClose
End Sub

' Intercepts the window close (X) button to guard unsaved changes across all tabs.
Sub MainForm_CloseRequest(EventData As Event)
	If AnyModified = False Then Return
	Dim jo As JavaObject = EventData
	jo.RunMethod("consume", Null)               ' cancel the close; we'll decide below
	PromptThenClose
End Sub

Sub PromptThenClose
	Wait For (ConfirmExit) Complete (proceed As Boolean)
	If proceed Then
		' clear modified flags so the close isn't re-intercepted
		Modified = False
		For Each d As Document In Documents
			d.modified = False
		Next
		MainForm.Close
	End If
End Sub

' Whole-app exit guard: prompts per unsaved document (Save / Don't Save / Cancel for each).
' Cancelling any one aborts the exit. AnyModified first flushes the active doc's globals into its
' Document so every d.modified flag is current.
Sub ConfirmExit As ResumableSub
	If AnyModified = False Then Return True
	For i = 0 To Documents.Size - 1
		Dim d As Document = Documents.Get(i)
		If d.modified Then
			tabs.SelectedIndex = i
			SwitchTo(i)                 ' mirror this doc into the globals so ConfirmDiscard targets it
			Wait For (ConfirmDiscard) Complete (proceed As Boolean)
			If proceed = False Then Return False    ' user cancelled - abort the whole exit
		End If
	Next
	Return True
End Sub

' Returns True if it's safe to discard the current document (saved, unmodified, or user agreed).
Sub ConfirmDiscard As ResumableSub
	If Not(Modified) Then Return True
	Dim sf As Object = xui.Msgbox2Async("Save changes to " & DocName & "?", APP_NAME, "Save", "Cancel", "Don't Save", Null)
	Wait For (sf) Msgbox_Result (res As Int)
	If res = xui.DialogResponse_Positive Then
		Wait For (SaveFile(False)) Complete (saved As Boolean)
		Return saved
	Else If res = xui.DialogResponse_Negative Then
		Return True
	Else
		Return False
	End If
End Sub
#End Region

#Region Edit operations
Sub mnuUndo_Action
	Editor.Undo
End Sub

Sub mnuRedo_Action
	Editor.Redo
End Sub

Sub mnuCut_Action
	Editor.Cut
End Sub

Sub mnuCopy_Action
	Editor.Copy
End Sub

Sub mnuPaste_Action
	Editor.Paste
End Sub

Sub mnuSelectAll_Action
	Editor.SelectAll
End Sub
